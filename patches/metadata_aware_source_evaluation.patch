+    def _extract_ground_truth_sources(self, ground_truth: Optional[Any]) -> List[str]:
+        """Extract expected source file names from ground truth."""
+        if ground_truth is None:
+            return []
+        if isinstance(ground_truth, dict):
+            sources = ground_truth.get("sources", [])
+            if isinstance(sources, list):
+                return [
+                    self._normalize_source_name(source)
+                    for source in sources
+                    if source
+                ]
+        return []
+
+    def _extract_expected_metadata(self, ground_truth: Optional[Any]) -> Dict[str, str]:
+        """Extract expected metadata constraints from ground truth."""
+        if not isinstance(ground_truth, dict):
+            return {}
+
+        metadata = ground_truth.get("expected_metadata", {})
+        if not isinstance(metadata, dict):
+            return {}
+
+        return {
+            str(key): str(value)
+            for key, value in metadata.items()
+            if value is not None
+        }
+
+    def _metadata_tokens_from_metadata(self, metadata: Dict[str, Any]) -> List[str]:
+        """Build source tokens from known metadata fields."""
+        tokens: List[str] = []
+
+        for fields in [
+            ("source_type",),
+            ("source_type", "source_paper"),
+            ("source_type", "source_paper", "modality"),
+        ]:
+            if all(field in metadata and metadata[field] is not None for field in fields):
+                expected = {
+                    field: str(metadata[field])
+                    for field in fields
+                }
+                tokens.append(self._metadata_token(expected))
+
+        return tokens
+
+    def _metadata_token(self, metadata: Dict[str, str]) -> str:
+        """Create stable token for metadata-based source matching."""
+        parts = [
+            f"{key}={metadata[key]}"
+            for key in sorted(metadata)
+        ]
+        return "metadata:" + ";".join(parts)
+
+    def _extract_sources(self, items: Iterable[Any]) -> List[str]:
+        """Extract source file names from retrieved chunks."""
+        sources: List[str] = []
+        for item in items:
+            source = None
+
+            if isinstance(item, dict):
+                metadata = item.get("metadata", {}) or {}
+                source = item.get("source_path") or item.get("source")
+                if not source and isinstance(metadata, dict):
+                    source = metadata.get("source_path") or metadata.get("source")
+            else:
+                metadata = getattr(item, "metadata", {}) or {}
+                if isinstance(metadata, dict):
+                    source = metadata.get("source_path") or metadata.get("source")
+
+            if source:
+                sources.append(self._normalize_source_name(source))
+
+            if isinstance(metadata, dict):
+                sources.extend(self._metadata_tokens_from_metadata(metadata))
+
+        return sources
+
+    def _normalize_source_name(self, source: Any) -> str:
+        """Normalize absolute paths to stable file names."""
+        value = str(source).replace("\\", "/").rstrip("/")
+        return value.split("/")[-1]
+
